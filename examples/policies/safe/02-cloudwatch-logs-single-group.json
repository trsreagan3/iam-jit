{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOneLogGroup",
      "Effect": "Allow",
      "Action": [
        "logs:GetLogEvents",
        "logs:FilterLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:us-east-1:123456789012:log-group:/aws/lambda/payment-processor:*"
    }
  ]
}
