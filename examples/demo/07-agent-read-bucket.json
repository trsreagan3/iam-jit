{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AgentReadProductCatalog",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::product-catalog-data",
        "arn:aws:s3:::product-catalog-data/*"
      ]
    }
  ]
}
