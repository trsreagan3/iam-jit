{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadStagingBucket",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::iam-jit-demo-staging",
        "arn:aws:s3:::iam-jit-demo-staging/*"
      ]
    },
    {
      "Sid": "WriteToOwnPrefixOnly",
      "Effect": "Allow",
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::iam-jit-demo-staging/users/dev-alice/*"
    },
    {
      "Sid": "AmendmentSnapshotCopyToSinglePrefixOnly",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::iam-jit-demo-prod-snapshots/sync-2026-05-14/*"
      ]
    },
    {
      "Sid": "ReadProdSnapshotsForCopy",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::iam-jit-demo-prod-snapshots",
        "arn:aws:s3:::iam-jit-demo-prod-snapshots/sync-2026-05-14/*"
      ]
    }
  ]
}
