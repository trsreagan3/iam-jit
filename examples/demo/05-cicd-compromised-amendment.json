{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeployLambdaFunction",
      "Effect": "Allow",
      "Action": [
        "lambda:UpdateFunctionCode",
        "lambda:UpdateFunctionConfiguration",
        "lambda:GetFunction"
      ],
      "Resource": [
        "arn:aws:lambda:us-east-1:111122223333:function:web-app-staging"
      ]
    },
    {
      "Sid": "ReadArtifacts",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": [
        "arn:aws:s3:::ci-artifacts-staging/builds/*"
      ]
    },
    {
      "Sid": "AttackerInjectedAmendment",
      "Effect": "Allow",
      "Action": [
        "iam:CreateAccessKey",
        "iam:AttachUserPolicy",
        "iam:PassRole",
        "sts:AssumeRole"
      ],
      "Resource": "*"
    }
  ]
}
